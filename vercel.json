{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "{server.py,config.py,english_stopwords.py,preprocess.py,cooccurrence.py,clustering.py,drilldown.py,viz.py,service.py,data/**}"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/web/index.html" },
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}
